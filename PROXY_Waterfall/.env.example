# ── JVM Settings ──────────────────────────────────────────────
JVM_MAX_HEAP=-Xmx2G
JVM_EXTRA_OPTS=-XX:+UseG1GC

# ── Waterfall Settings ────────────────────────────────────────
PROXY_PORT=25565
PROXY_HOST=0.0.0.0:25565
PROXY_MOTD=Freesia Waterfall Proxy
PROXY_MAX_PLAYERS=500
PROXY_ONLINE_MODE=false

# ── TLS / mTLS (Base64 Injection) ──────────────────────────────
PROXY_CERT_B64=
PROXY_KEY_B64=
