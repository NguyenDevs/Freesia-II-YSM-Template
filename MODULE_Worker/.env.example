# =============================================================
# .env — Freesia MODULE_Worker
# Copy .env.example to .env and fill in real values
# =============================================================

# ── JVM Tuning ────────────────────────────────────────────────
JVM_MAX_HEAP=-Xmx5G
JVM_MIN_HEAP=-Xms512M
# Extra JVM flags (e.g., GC tuning)
JVM_EXTRA_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+UnlockExperimentalVMOptions -XX:G1NewSizePercent=20 -XX:G1ReservePercent=20

# ── Minecraft Server ───────────────────────────────────────────
MC_PORT=19199
MC_BIND_IP=0.0.0.0
MC_MAX_PLAYERS=2000
# true = valid Mojang account required, false = cracked mode (requires BungeeCord/Velocity online-mode)
MC_ONLINE_MODE=false
MC_MOTD=Freesia Worker Node
MC_DIFFICULTY=peaceful
MC_GAMEMODE=survival
MC_PVP=false
MC_ALLOW_NETHER=false
MC_GENERATE_STRUCTURES=false
MC_VIEW_DISTANCE=1
MC_SIMULATION_DISTANCE=1
MC_COMPRESSION_THRESHOLD=256
MC_PREVENT_PROXY=false
MC_ENFORCE_SECURE_PROFILE=false
MC_SPAWN_ANIMALS=false
MC_SPAWN_MONSTERS=false
MC_SPAWN_NPCS=false
MC_MAX_TICK_TIME=60000
MC_LOG_IPS=false

# ── Deep Optimization (Background Server) ──────────────────────
MC_LEVEL_TYPE=flat
MC_SYNC_CHUNK_WRITES=false
MC_ENTITY_BROADCAST=10

# ── Freesia Worker Connection ──────────────────────────────────
FREESIA_RECONNECT_INTERVAL=5
FREESIA_CACHE_INVALIDATE=30

# ── TLS / mTLS ─────────────────────────────────────────────────
FREESIA_TLS_ENABLED=true
FREESIA_TRUST_ALL=false

# If NOT mounting ./config/security into the container,
# fill in certificates in base64 format here:
# (Encode command: base64 -w0 worker_cert.pem)
WORKER_CERT_B64=
WORKER_KEY_B64=
PROXY_CERT_B64=