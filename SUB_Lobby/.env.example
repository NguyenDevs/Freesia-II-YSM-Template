# ── JVM Settings ──────────────────────────────────────────────
JVM_MAX_HEAP=-Xmx2G
JVM_MIN_HEAP=-Xms512M
JVM_EXTRA_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ── Minecraft Settings ────────────────────────────────────────
MC_PORT=25566
MC_BIND_IP=0.0.0.0
MC_MAX_PLAYERS=200
MC_ONLINE_MODE=false
MC_MOTD=Freesia Sub Lobby

# Game Settings
MC_DIFFICULTY=peaceful
MC_GAMEMODE=adventure
MC_PVP=true
MC_SPAWN_PROTECTION=1

# World Settings
MC_VIEW_DISTANCE=10
MC_SIMULATION_DISTANCE=10
MC_ALLOW_NETHER=false
MC_GENERATE_STRUCTURES=false

# Advanced
MC_MAX_TICK_TIME=60000
MC_NETWORK_COMPRESSION_THRESHOLD=256
