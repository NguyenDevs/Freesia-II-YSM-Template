# ── JVM Settings ──────────────────────────────────────────────
JVM_MAX_HEAP=-Xmx2G
JVM_MIN_HEAP=-Xms512M
JVM_EXTRA_OPTS=-XX:+UseG1GC -XX:MaxGCPauseMillis=200

# ── Velocity Settings ─────────────────────────────────────────
PROXY_PORT=25565
PROXY_BIND=0.0.0.0:25565
PROXY_MOTD=Freesia Velocity Proxy
PROXY_SHOW_MAX_PLAYERS=500
PROXY_ONLINE_MODE=false

# Forwarding Mode: MODERN, LEGACY, BUNGEEGUARD, NONE
PROXY_FORWARDING_MODE=MODERN
PROXY_KICK_EXISTING=false
PROXY_FORCE_KEY_AUTH=true

# ── Freesia Plugin Settings ───────────────────────────────────
# Port for Workers to connect to (Netty Port)
PROXY_FREESIA_PORT=19200

# ── TLS / mTLS (Base64 Injection) ──────────────────────────────
# Fill these if you want Docker to create the files automatically
PROXY_CERT_B64=
PROXY_KEY_B64=
